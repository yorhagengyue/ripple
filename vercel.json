{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/",              "destination": "/ripple/index.html" },
    { "source": "/vitals",        "destination": "/ripple/vitals.html" },
    { "source": "/timeline",      "destination": "/ripple/timeline.html" },
    { "source": "/pipeline",      "destination": "/ripple/pipeline.html" },
    { "source": "/chat",          "destination": "/ripple/chat.html" },
    { "source": "/demo",          "destination": "/ripple/demo.html" },
    { "source": "/peer",          "destination": "/peer/index.html" },
    { "source": "/peer/u/:profile", "destination": "/peer/chat.html" }
  ],
  "headers": [
    {
      "source": "/peer/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    },
    {
      "source": "/peer",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ]
}
